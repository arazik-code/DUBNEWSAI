ENVIRONMENT=production
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-SUPABASE-PASSWORD]@db.[YOUR-SUPABASE-PROJECT-REF].supabase.co:5432/postgres

FRONTEND_URL=https://your-frontend.vercel.app
CORS_ORIGINS=https://your-frontend.vercel.app

SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Upstash REST credentials
UPSTASH_REDIS_REST_URL=https://[YOUR-UPSTASH-ENDPOINT].upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Required for the current Redis/Celery setup.
# Use the Upstash Redis TCP password here, not the REST token.
REDIS_URL=rediss://:CHANGE_ME_UPSTASH_REDIS_PASSWORD@[YOUR-UPSTASH-ENDPOINT].upstash.io:6379/0
CELERY_BROKER_URL=rediss://:CHANGE_ME_UPSTASH_REDIS_PASSWORD@[YOUR-UPSTASH-ENDPOINT].upstash.io:6379/1
CELERY_RESULT_BACKEND=rediss://:CHANGE_ME_UPSTASH_REDIS_PASSWORD@[YOUR-UPSTASH-ENDPOINT].upstash.io:6379/2

NEWSAPI_KEY=
ALPHA_VANTAGE_KEY=
RESEND_API_KEY=
